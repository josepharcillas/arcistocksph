---
// Registers the service worker and shows a "new version available" banner when
// an updated SW is waiting. Included on every page because the app is an MPA —
// each route is a fresh document and must register the SW itself. This is what
// stops users (and the /login page in particular) from getting stuck on a stale
// cached bundle after a deploy.
---
<div
  id="pwa-update-toast"
  class="hidden fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:w-80 bg-slate-900 border border-green-600 rounded-xl p-4 shadow-xl z-[60]"
>
  <p class="text-white text-sm font-semibold">Update available</p>
  <p class="text-slate-400 text-xs mt-0.5">A new version of ArciStocks PH is ready.</p>
  <div class="flex gap-2 mt-2">
    <button
      id="pwa-update-refresh"
      class="bg-green-500 hover:bg-green-400 text-slate-950 font-semibold text-xs px-3 py-1.5 rounded-lg transition-colors"
    >Refresh</button>
    <button
      id="pwa-update-dismiss"
      class="text-slate-500 hover:text-white text-xs px-2 py-1.5 transition-colors"
    >Later</button>
  </div>
</div>
<script>
  import { registerSW } from 'virtual:pwa-register';

  const toast = document.getElementById('pwa-update-toast');
  const updateSW = registerSW({
    onNeedRefresh() {
      toast?.classList.remove('hidden');
    },
    onRegisteredSW(_swUrl, registration) {
      // Re-check for a new service worker hourly while the tab stays open, so a
      // long-lived session still picks up deploys without a manual reload.
      if (registration) {
        setInterval(() => registration.update(), 60 * 60 * 1000);
      }
    },
  });

  document.getElementById('pwa-update-refresh')?.addEventListener('click', () => updateSW(true));
  document.getElementById('pwa-update-dismiss')?.addEventListener('click', () => toast?.classList.add('hidden'));
</script>
