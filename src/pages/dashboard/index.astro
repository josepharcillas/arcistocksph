---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import HoldingsList from '../../components/portfolio/HoldingsList';
---
<DashboardLayout title="Portfolio">
  <div class="p-4 md:p-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold">My Portfolio</h1>
      <p class="text-slate-400 text-sm mt-0.5">Track your PSE holdings and P&L</p>
    </div>

    <HoldingsList client:load />

    <p class="text-slate-600 text-xs mt-8 text-center">
      This tool is for educational purposes only and does not constitute financial advice.
    </p>
  </div>
</DashboardLayout>
