---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import NotificationSettings from '../../components/pwa/NotificationSettings';
---
<DashboardLayout title="Notifications">
  <div class="p-4 md:p-6 max-w-2xl">
    <div class="mb-6">
      <h1 class="text-2xl font-bold">🔔 Notifications</h1>
      <p class="text-slate-400 text-sm mt-0.5">Manage push alerts for your holdings</p>
    </div>

    <NotificationSettings client:load />

    <p class="text-slate-600 text-xs mt-8 text-center">
      Alerts are informational only and not financial advice.
    </p>
  </div>
</DashboardLayout>
