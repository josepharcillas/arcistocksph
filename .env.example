# Supabase
PUBLIC_SUPABASE_URL=your_supabase_project_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only — used by the leaderboard aggregation API. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Providers — app auto-picks Gemini if set, falls back to Groq
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional: override the Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# Fundamentals API (P/E, EPS, dividend yield) — PSE Edge doesn't expose these.
# Key-gated: leave blank and the app runs as before (fundamentals stay null).
# Provider: eodhd (default, symbol TICKER.PSE) or twelvedata.
# NOTE: PSE fundamentals are often a PAID add-on on these providers' plans.
FUNDAMENTALS_API_KEY=
FUNDAMENTALS_PROVIDER=eodhd

# Web Push (VAPID). Generate a keypair once: npx web-push generate-vapid-keys
PUBLIC_FCM_VAPID_KEY=        # VAPID *public* key — safe to expose to the browser
VAPID_PRIVATE_KEY=          # VAPID *private* key — server-only, never expose
VAPID_SUBJECT=mailto:you@example.com
# Shared secret guarding POST /api/push/notify so only your own cron/job can fan out pushes
PUSH_NOTIFY_SECRET=
